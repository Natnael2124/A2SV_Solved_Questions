def solve():
    t = int(input())
    for _ in range(t):
        n,k = map(int,input().split())
        s = input()

        j = 0
        count=float("inf")
        w = 0
        for i in range(n-k+1):
            while j -i < k :
                if s[j] == "W":
                    w += 1
                j += 1
            count = min(w,count)
            if s[i] == "W":
                w -= 1
        print(count)
    
if __name__ == "__main__":
    solve()


